    "@warehouse/database": "workspace:*",
    "bcrypt": "latest",
    "bullmq": "5.79.0",
    "ioredis": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@nestjs/cli": "latest",
    "@nestjs/testing": "latest",
    "@types/bcrypt": "latest",
    "@types/express": "latest",
    "@types/supertest": "latest",
    "supertest": "latest"
  }
